        },
        {
          "id": "a2-word-fish",
          "type": "speech",
          "prompt": "Say the word: FISH",
          "target": "fish",
          "phonetic": "FISH",
          "reps": 3
        },
        {
          "id": "a2-word-safe",
          "type": "speech",
          "prompt": "Say the word: SAFE",
          "target": "safe",
          "phonetic": "SAYF",
          "reps": 3
        },
        {
          "id": "a2-word-five",
          "type": "speech",
          "prompt": "Say the word: FIVE",
          "target": "five",
          "phonetic": "FYVE",
          "reps": 2
        },
        {
          "id": "a2-word-sun",
          "type": "speech",
          "prompt": "Say the word: SUN",
          "target": "sun",
          "phonetic": "SUHN",
          "reps": 2
        },
        {
          "id": "a2-fa-sa-contrast",
          "type": "speech",
          "prompt": "Say: fa — sa — fa — sa. Feel the difference between lip and tongue.",
          "target": "fa sa fa sa",
          "phonetic": "fah — sah — fah — sah",
          "reps": 3
        },
        {
          "id": "a2-word-sofa",
          "type": "speech",
          "prompt": "Say the word: SOFA — it has both S and F!",
          "target": "sofa",
          "phonetic": "SOH-fuh",
          "reps": 3
        }
      ]
    },
    {
